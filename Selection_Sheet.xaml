<Window x:Class="Brand_25.Selection_Sheet"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Brand_25"
        Title="Select Sheets" 
        Height="600" Width="1200" 
        WindowStartupLocation="CenterScreen"
        Background="LightGray" 
        WindowStyle="None">

    <WindowChrome.WindowChrome>
        <WindowChrome GlassFrameThickness="0" CornerRadius="0" CaptionHeight="0"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <!-- Converters -->
        <local:InverseBoolConverter x:Key="InverseBoolConverter"/>
        <local:BoolToOpacityConverter x:Key="BoolToOpacityConverter"/>

        <!-- Styles -->
        <Style x:Key="TitleBarButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="bdr_main" BorderThickness="1" BorderBrush="Transparent" Background="Transparent">
                            <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Center" ContentSource="Content"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bdr_main" Property="Background" Value="#a7a7a7"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bdr_main" Property="Background" Value="#979797"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CustomButtonFontStyle" TargetType="Button">
            <Setter Property="FontFamily" Value="Calibri"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Regular"/>
        </Style>

        <Style x:Key="CustomFontStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Calibri"/>
            <Setter Property="FontWeight" Value="Regular"/>
        </Style>
    </Window.Resources>

    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="35"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="72"/>
        </Grid.RowDefinitions>

        <!-- Title Bar -->
        <Grid Grid.Row="0" MouseLeftButtonDown="Window_MouseLeftButtonDown" Background="#474747">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="105"/>
            </Grid.ColumnDefinitions>

            <StackPanel Orientation="Horizontal" Background="Transparent" HorizontalAlignment="Left" VerticalAlignment="Center">
                <Image x:Name="icon" Width="25" Height="25" Margin="5 0 0 0"/>
                <TextBlock Foreground="White" Name="TitleText" FontSize="16" VerticalAlignment="Center" Margin="10 0 0 0"
                           Style="{StaticResource CustomFontStyle}"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Grid.Column="1" Background="#474747">
                <Button Style="{StaticResource TitleBarButtonStyle}" x:Name="buttonMinimize" Width="35" 
                        Background="Transparent" BorderBrush="Transparent" Click="buttonMinimize_Click">
                    <Image x:Name="minimizeImage" Width="20" Height="20"/>
                </Button>
                <Button Style="{StaticResource TitleBarButtonStyle}" x:Name="buttonMaximize" Width="35" 
                        Background="Transparent" BorderBrush="Transparent" Click="buttonMaximize_Click">
                    <Image x:Name="maximizeImage" Width="20" Height="20"/>
                </Button>
                <Button Style="{StaticResource TitleBarButtonStyle}" x:Name="buttonClose" Width="35" 
                        Background="Transparent" BorderBrush="Transparent" Click="buttonClose_Click">
                    <Image x:Name="closeImage" Width="20" Height="20"/>
                </Button>
            </StackPanel>
        </Grid>

        <!-- DataGrid -->
        <DataGrid x:Name="SheetsDataGrid" Grid.Row="1" AutoGenerateColumns="False" 
                  SelectionMode="Extended" Background="LightGray" Margin="10">
            <DataGrid.Columns>
                <DataGridTemplateColumn Header=" " Width="Auto">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                                      HorizontalAlignment="Center"
                                      Click="CheckBox_Click"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTextColumn Header="Sheet Number" Binding="{Binding SheetNumber}" Width="Auto"/>
                <DataGridTextColumn Header="Sheet Name" Binding="{Binding SheetName}" Width="3*"/>
                <DataGridTextColumn Header="Sheet Series" Binding="{Binding SheetSeries}" Width="*"/>
                <DataGridTextColumn Header="Current Revision" Binding="{Binding CurrentRevision}" Width="Auto"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="10 0 0 10" Width="400">
            <Button Style="{StaticResource CustomButtonFontStyle}" Content="Select Sheet(s)" Width="130" Margin="0 0 10 0" Click="OK_Click"/>
            <Button Style="{StaticResource CustomButtonFontStyle}" Content="Select None" Width="100" Margin="0 0 10 0" Click="SelectNone_Click"/>
            <Button Style="{StaticResource CustomButtonFontStyle}" Content="Cancel" Width="80" Click="Cancel_Click"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Vertical" HorizontalAlignment="Right" Margin="0 0 10 10">
            <Image x:Name="brandLogo" Width="150" Height="50" VerticalAlignment="Top" HorizontalAlignment="Right"/>
            <TextBlock x:Name="FooterText" Style="{StaticResource CustomFontStyle}" FontSize="12" Foreground="White" 
                       HorizontalAlignment="Right" VerticalAlignment="Bottom"/>
        </StackPanel>
    </Grid>
</Window>