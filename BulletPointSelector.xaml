<Window x:Class="Brand_25.BulletPointSelector"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Selection Dialog" Height="360" Width="540" WindowStartupLocation="CenterScreen"
        Background="LightGray"
        WindowStyle="None" ResizeMode="NoResize"
        Name="BulletPointSelectorWindow">

    <WindowChrome.WindowChrome>
        <WindowChrome GlassFrameThickness="0" CornerRadius="0" CaptionHeight="0"/>
    </WindowChrome.WindowChrome>
    <Window.Resources>
        <Style x:Key="TitleBarButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="bdr_main" BorderThickness="1" BorderBrush="Transparent" Background="Transparent">
                            <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Center" ContentSource="Content"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bdr_main" Property="Background" Value="#a7a7a7"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bdr_main" Property="Background" Value="#979797"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="CustomButtonFontStyle" TargetType="Button">
            <Setter Property="FontFamily" Value="Calibri"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Regular"/>
        </Style>
        <Style x:Key="CustomFontStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Calibri"/>
            <Setter Property="FontWeight" Value="Regular"/>
        </Style>
        <Style x:Key="CheckBoxStyle" TargetType="CheckBox">
            <Setter Property="FontFamily" Value="Calibri"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Foreground" Value="#272727"/>
        </Style>
    </Window.Resources>

    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="35"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="72"/>
        </Grid.RowDefinitions>

        <!-- Title Bar -->
        <Grid Grid.Row="0" Background="#474747" MouseLeftButtonDown="Window_MouseLeftButtonDown">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="35"/>
            </Grid.ColumnDefinitions>
            
            <!--<Rectangle Grid.Column="0" Fill="#474747" />-->
            <StackPanel Orientation ="Horizontal" Background="Transparent" HorizontalAlignment="left" VerticalAlignment="Center">
                <Image x:Name="icon" Width="25" Height="25" Margin="5 0 0 0"/>
                <TextBlock Foreground="White" Name="TitleText" FontSize="16" VerticalAlignment="Center" Margin="10 0 0 0"
                           Style="{StaticResource CustomFontStyle}"/>
                <StackPanel.Style>
                    <Style TargetType="StackPanel">
                        <Setter Property="Background" Value="Transparent"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#575757"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </StackPanel.Style>
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Grid.Column="1" Background="#474747" >
                <Button Style="{StaticResource TitleBarButtonStyle}" x:Name="buttonClose" Width="35" Background="Transparent" BorderBrush="Transparent"
                        Click="buttonClose_Click">
                    <Image x:Name="closeImage" Width="20" Height="20"/>
                </Button>
            </StackPanel>
        </Grid>

        <!-- Instruction Text -->
        <TextBlock Name="InstructionText" Grid.Row="1"
                   TextWrapping="Wrap" TextAlignment="Left"
                   Style="{StaticResource CustomFontStyle}" 
                   FontSize="20" Foreground="#272727"
                   Margin="10" VerticalAlignment="Top"/>

        <!-- Dynamic Checkboxes Area (now handles custom input inline) -->
        <ScrollViewer Grid.Row="2" Margin="10 5 10 5" VerticalScrollBarVisibility="Auto">
            <StackPanel x:Name="CheckBoxPanel" Orientation="Vertical"/>
        </ScrollViewer>
        
        <!-- Action Buttons -->
        <Button Content="OK" Width="80" Height="30" Click="CloseDialog" 
                Style="{StaticResource CustomButtonFontStyle}"
                HorizontalAlignment="Left" Grid.Row="3" VerticalAlignment="Bottom"
                Margin="10 0 0 10"/>

        <!-- Footer -->
        <StackPanel Orientation="Vertical" HorizontalAlignment="Right" Grid.Row="3" Margin="0 0 10 10" >
            <Image x:Name="brandLogo" Width="150" Height="50" 
                   VerticalAlignment="Top" HorizontalAlignment="Right" 
                   Margin="0 0 0 0"/>
            <TextBlock x:Name="FooterText" Style="{StaticResource CustomFontStyle}" FontSize="12" Foreground="white" 
                       HorizontalAlignment="Right" 
                       VerticalAlignment="Bottom"/>
        </StackPanel>
    </Grid>
</Window>