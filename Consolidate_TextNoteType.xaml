<Window x:Class="Brand_25.Consolidate_TextNoteType"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Duplicate Text Note Types"
        Height="700" Width="1600"
        WindowStartupLocation="CenterScreen"
        Background="LightGray"
        WindowStyle="None">

    <WindowChrome.WindowChrome>
        <WindowChrome GlassFrameThickness="0" CornerRadius="0" CaptionHeight="0"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <Style x:Key="TitleBarButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="bdr_main" BorderThickness="1" BorderBrush="Transparent" Background="Transparent">
                            <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Center" ContentSource="Content"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bdr_main" Property="Background" Value="#a7a7a7"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bdr_main" Property="Background" Value="#979797"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CustomButtonFontStyle" TargetType="Button">
            <Setter Property="FontFamily" Value="Calibri"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Regular"/>
        </Style>

        <Style x:Key="CustomFontStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Calibri"/>
            <Setter Property="FontWeight" Value="Regular"/>
        </Style>
    </Window.Resources>

    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="35"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="72"/>
        </Grid.RowDefinitions>

        <!-- Title Bar -->
        <Grid Grid.Row="0" MouseLeftButtonDown="Window_MouseLeftButtonDown" Background="#474747">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="105"/>
            </Grid.ColumnDefinitions>

            <StackPanel Orientation="Horizontal" Background="Transparent" HorizontalAlignment="Left" VerticalAlignment="Center">
                <Image x:Name="icon" Width="25" Height="25" Margin="5 0 0 0"/>
                <TextBlock Foreground="White" Name="TitleText" FontSize="16" VerticalAlignment="Center" Margin="10 0 0 0"
                           Style="{StaticResource CustomFontStyle}"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Grid.Column="1" Background="#474747">
                <Button Style="{StaticResource TitleBarButtonStyle}" x:Name="buttonMinimize" Width="35"
                        Background="Transparent" BorderBrush="Transparent" Click="buttonMinimize_Click">
                    <Image x:Name="minimizeImage" Width="20" Height="20"/>
                </Button>
                <Button Style="{StaticResource TitleBarButtonStyle}" x:Name="buttonMaximize" Width="35"
                        Background="Transparent" BorderBrush="Transparent" Click="buttonMaximize_Click">
                    <Image x:Name="maximizeImage" Width="20" Height="20"/>
                </Button>
                <Button Style="{StaticResource TitleBarButtonStyle}" x:Name="buttonClose" Width="35"
                        Background="Transparent" BorderBrush="Transparent" Click="buttonClose_Click">
                    <Image x:Name="closeImage" Width="20" Height="20"/>
                </Button>
            </StackPanel>
        </Grid>

        <!-- Subtitle -->
        <TextBlock x:Name="SubtitleText" Grid.Row="1"
                   TextWrapping="Wrap" FontSize="20" Foreground="#272727"
                   Style="{StaticResource CustomFontStyle}"
                   Margin="15 8 15 4"/>

        <!-- Table — every candidate across every duplicate group. Shaded rows share a
             group. The Survivor column is static (defined here); every attribute column
             is added in code-behind via TextNoteAttributeCatalog.BuildAllColumns, which
             greys out attributes that weren't part of the comparison. -->
        <DataGrid x:Name="SurvivorGrid" Grid.Row="2"
                  AutoGenerateColumns="False" IsReadOnly="True"
                  SelectionMode="Single" CanUserSortColumns="False"
                  VirtualizingPanel.IsVirtualizing="False"
                  Background="LightGray" Margin="10">

            <DataGrid.CellStyle>
                <Style TargetType="DataGridCell">
                    <Setter Property="Padding" Value="8,4,8,4"/>
                    <!-- Change this to Center (or Right) to align every cell's contents -->
                    <Setter Property="HorizontalContentAlignment" Value="Center"/>
                </Style>
            </DataGrid.CellStyle>

            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding GroupShade}" Value="True">
                            <Setter Property="Background" Value="#D6E4F0"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding GroupShade}" Value="False">
                            <Setter Property="Background" Value="#FDFEFE"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.RowStyle>

            <DataGrid.Columns>
                <DataGridTemplateColumn Header="Survivor" Width="70" CanUserSort="False">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <RadioButton HorizontalAlignment="Center" VerticalAlignment="Center"
                                         IsChecked="{Binding IsSurvivor, Mode=TwoWay}"
                                         Checked="SurvivorRadio_Checked"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Footer -->
        <Grid Grid.Row="3">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="10 0 0 10">
                <Button Style="{StaticResource CustomButtonFontStyle}" Content="Consolidate"
                        Width="120" Margin="0 0 10 0" Click="Consolidate_Click"/>
                <Button Style="{StaticResource CustomButtonFontStyle}" Content="Cancel"
                        Width="90" Click="Cancel_Click"/>
            </StackPanel>

            <StackPanel Orientation="Vertical" HorizontalAlignment="Right" Margin="0 0 10 10">
                <Image x:Name="brandLogo" Width="150" Height="50" VerticalAlignment="Top" HorizontalAlignment="Right"/>
                <TextBlock x:Name="FooterText" Style="{StaticResource CustomFontStyle}" FontSize="12" Foreground="White"
                           HorizontalAlignment="Right" VerticalAlignment="Bottom"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
