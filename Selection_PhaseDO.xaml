<Window x:Class="Brand_25.Selection_PhaseDO"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Selection Dialog" Height="480" Width="500" WindowStartupLocation="CenterScreen"
        Background="LightGray"
        WindowStyle="None" ResizeMode="NoResize"
        Name="Selection_PhaseDOWindow">

    <WindowChrome.WindowChrome>
        <WindowChrome GlassFrameThickness="0" CornerRadius="0" CaptionHeight="0"/>
    </WindowChrome.WindowChrome>
    <Window.Resources>
        <Style x:Key="TitleBarButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="bdr_main" BorderThickness="1" BorderBrush="Transparent" Background="Transparent">
                            <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Center" ContentSource="Content"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bdr_main" Property="Background" Value="#a7a7a7"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bdr_main" Property="Background" Value="#979797"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="CustomButtonFontStyle" TargetType="Button">
            <Setter Property="FontFamily" Value="Calibri"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Regular"/>
        </Style>
        <Style x:Key="CustomFontStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Calibri"/>
            <Setter Property="FontWeight" Value="Regular"/>
        </Style>
        <Style x:Key="CheckBoxStyle" TargetType="CheckBox">
            <Setter Property="FontFamily" Value="Calibri"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Margin" Value="5 5 0 0"/>
            <Setter Property="Foreground" Value="#272727"/>
        </Style>
        <Style x:Key="ComboBoxLabelStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Calibri"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Foreground" Value="#272727"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="5 0 0 0"/>
        </Style>
        <Style x:Key="CustomComboBoxStyle" TargetType="ComboBox">
            <Setter Property="FontFamily" Value="Calibri"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Width" Value="320"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="NumericLabelStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Calibri"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Foreground" Value="#272727"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Width" Value="375"/>
        </Style>
        <Style x:Key="NumericBoxStyle" TargetType="TextBox">
            <Setter Property="FontFamily" Value="Calibri"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Width" Value="90"/>
            <Setter Property="Height" Value="26"/>
            <Setter Property="Padding" Value="4 2 4 2"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <Setter Property="HorizontalContentAlignment" Value="Right"/>
        </Style>
    </Window.Resources>

    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="35"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="72"/>
        </Grid.RowDefinitions>

        <!-- Title Bar -->
        <Grid Grid.Row="0" Background="#474747" MouseLeftButtonDown="Window_MouseLeftButtonDown">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="35"/>
            </Grid.ColumnDefinitions>

            <StackPanel Orientation ="Horizontal" Background="Transparent" HorizontalAlignment="left" VerticalAlignment="Center">
                <Image x:Name="icon" Width="25" Height="25" Margin="5 0 0 0"/>
                <TextBlock Foreground="White" Name="TitleText" FontSize="16" VerticalAlignment="Center" Margin="10 0 0 0"
                           Style="{StaticResource CustomFontStyle}"/>
                <StackPanel.Style>
                    <Style TargetType="StackPanel">
                        <Setter Property="Background" Value="Transparent"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#575757"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </StackPanel.Style>
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Grid.Column="1" Background="#474747" >
                <Button Style="{StaticResource TitleBarButtonStyle}" x:Name="buttonClose" Width="35" Background="Transparent" BorderBrush="Transparent"
                        Click="buttonClose_Click">
                    <Image x:Name="closeImage" Width="20" Height="20"/>
                </Button>
            </StackPanel>
        </Grid>

        <!-- Instruction Text -->
        <TextBlock Name="InstructionText" Grid.Row="1"
                   TextWrapping="Wrap" TextAlignment="Left"
                   Style="{StaticResource CustomFontStyle}"
                   FontSize="20" Foreground="#272727"
                   Margin="15, 20, 17, 12" VerticalAlignment="Top"/>

        <!-- Phase / Design Option Row -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="10 0 12 10">
            <TextBlock Text="Phase:" Style="{StaticResource ComboBoxLabelStyle}" Width="150"/>
            <ComboBox x:Name="PhaseComboBox" Style="{StaticResource CustomComboBoxStyle}"/>
        </StackPanel>
        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="10 0 12 15">
            <TextBlock Text="Design Option:" Style="{StaticResource ComboBoxLabelStyle}" Width="150"/>
            <ComboBox x:Name="DesignOptionComboBox" Style="{StaticResource CustomComboBoxStyle}"/>
        </StackPanel>

        <!-- Mode-specific area: tie-break bullets (Win_AssignMark) OR numeric
             crop/marker fields (elevation creation) — exactly one is visible,
             toggled in code-behind based on the showNumericFields constructor flag. -->
        <Grid Grid.Row="4" Margin="10 0 12 0">
            <StackPanel x:Name="TieBreakContainer">
                <TextBlock Text="For interior ones, mark elements after the room with:" Style="{StaticResource CustomFontStyle}" FontSize="20" Margin="5 25 5 5"/>
                <UniformGrid x:Name="TieBreakPanel" Columns="1" Margin="0 0 10 0" VerticalAlignment="Top"/>
            </StackPanel>

            <ScrollViewer x:Name="NumericFieldsContainer" VerticalScrollBarVisibility="Auto" Visibility="Collapsed">
                <StackPanel Margin="5 0 5 0">
                    <TextBlock Text="Crop Box Settings (mm):" Style="{StaticResource ComboBoxLabelStyle}" Margin="0 10 0 10"/>

                    <StackPanel Orientation="Horizontal" Margin="0 0 0 2">
                        <TextBlock Text="Left/Right Margin:" Style="{StaticResource NumericLabelStyle}"/>
                        <TextBox x:Name="SideExtentBox" Style="{StaticResource NumericBoxStyle}"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0 0 0 2">
                        <TextBlock Text="Top Margin:" Style="{StaticResource NumericLabelStyle}"/>
                        <TextBox x:Name="TopExtentBox" Style="{StaticResource NumericBoxStyle}"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0 0 0 2">
                        <TextBlock Text="Bottom Extent below floor line (negative expected):" Style="{StaticResource NumericLabelStyle}"/>
                        <TextBox x:Name="BottomExtentBox" Style="{StaticResource NumericBoxStyle}"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0 0 0 2">
                        <TextBlock Text="Far Clip Offset:" Style="{StaticResource NumericLabelStyle}"/>
                        <TextBox x:Name="FarClipBox" Style="{StaticResource NumericBoxStyle}"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0 0 0 2">
                        <TextBlock Text="Marker Offset from Window (negative expected):" Style="{StaticResource NumericLabelStyle}"/>
                        <TextBox x:Name="MarkerOffsetBox" Style="{StaticResource NumericBoxStyle}"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0 0 0 10">
                        <TextBlock Text="Drawing Scale:" Style="{StaticResource NumericLabelStyle}"/>
                        <TextBox x:Name="MarkerRadiusBox" Style="{StaticResource NumericBoxStyle}"/>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- Action Buttons -->
        <Button Content="OK" Width="80" Height="30" Click="CloseDialog"
                Style="{StaticResource CustomButtonFontStyle}"
                HorizontalAlignment="Left" Grid.Row="5" VerticalAlignment="Bottom"
                Margin="17 0 0 10"/>

        <!-- Footer -->
        <StackPanel Orientation="Vertical" HorizontalAlignment="Right" Grid.Row="5" Margin="0 0 10 10" >
            <Image x:Name="brandLogo" Width="150" Height="50"
                   VerticalAlignment="Top" HorizontalAlignment="Right"
                   Margin="0 0 0 0"/>
            <TextBlock x:Name="FooterText" Style="{StaticResource CustomFontStyle}" FontSize="12" Foreground="white"
                       HorizontalAlignment="Right"
                       VerticalAlignment="Bottom"/>
        </StackPanel>
    </Grid>
</Window>
