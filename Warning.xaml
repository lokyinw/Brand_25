<Window x:Class="Brand_25.Warning"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Warning" Height="270" Width="400" WindowStartupLocation="CenterScreen"
        Background="LightGray"
        WindowStyle="None" ResizeMode="NoResize">

    <WindowChrome.WindowChrome>
        <WindowChrome GlassFrameThickness="0" CornerRadius="0" CaptionHeight="0"/>
    </WindowChrome.WindowChrome>
    <Window.Resources>
        <Style x:Key="TitleBarButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="bdr_main" BorderThickness="1" BorderBrush="Transparent" Background="Transparent">
                            <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Center" ContentSource="Content"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bdr_main" Property="Background" Value="#a7a7a7"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bdr_main" Property="Background" Value="#979797"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="CustomButtonFontStyle" TargetType="Button">
            <Setter Property="FontFamily" Value="Calibri"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Regular"/>
        </Style>
        <Style x:Key="CustomFontStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Calibri"/>
            <Setter Property="FontWeight" Value="Regular"/>            
        </Style>
    </Window.Resources>

    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="35"/>
            <RowDefinition Height="*" />
            <RowDefinition Height="72"/>
            
            
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" MouseLeftButtonDown="Window_MouseLeftButtonDown" Background="#474747">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="35"/>
            </Grid.ColumnDefinitions>
            <StackPanel Orientation ="Horizontal" Background="Transparent" HorizontalAlignment="left" VerticalAlignment="Center">
                <Image x:Name="icon" Width="25" Height="25" Margin="5 0 0 0"/>
                <TextBlock Foreground="White" Name="TitleText" FontSize="16" VerticalAlignment="Center" Margin="10 0 0 0"
                           Style="{StaticResource CustomFontStyle}"/>
            </StackPanel>


            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Grid.Column="1" Background="#474747" >
                <!--<Button Style="{StaticResource TitleBarButtonStyle}" x:Name="buttonMinimize" Width="35" Background="Transparent" BorderBrush="Transparent"
                        Click="buttonMinimize_Click">
                    <Image x:Name="minimizeImage" Width="20" Height="20"/>
                </Button>
                <Button Style="{StaticResource TitleBarButtonStyle}" x:Name="buttonMaximize" Width="35" Background="Transparent" BorderBrush="Transparent"
                         Click="buttonMaximize_Click">
                    <Image x:Name="maximizeImage" Width="20" Height="20"/>
                </Button>-->
                <Button Style="{StaticResource TitleBarButtonStyle}" x:Name="buttonClose" Width="35" Background="Transparent" BorderBrush="Transparent"
                        Click="buttonClose_Click">
                    <Image x:Name="closeImage" Width="20" Height="20"/>
                </Button>
            </StackPanel>
        </Grid>

        <!-- FontSize is a design-time default (20) — overridden in code-behind from the
             optional messageFontSize constructor parameter, so existing call sites that
             don't pass it keep this exact look. -->
        <TextBlock Name="MessageText" TextWrapping="Wrap" TextAlignment="Left" Grid.Row="1"
                   Style="{StaticResource CustomFontStyle}" FontSize="20" Foreground="#272727"
                   Margin="10" VerticalAlignment="Top"/>
                   

        <Button Content="OK" Width="80" Height="30" Click="CloseDialog" 
                Style="{StaticResource CustomButtonFontStyle}"
                HorizontalAlignment="Left" Grid.Row="2" VerticalAlignment="Bottom"
                Margin="10 0 0 10"/>

        <!-- Hidden by default — only shown when the calling script passes a non-empty
             revealPath into the constructor, so existing callers see no change. -->
        <Button x:Name="OpenFolderButton" Content="Open Folder" Width="110" Height="30"
                Click="OpenFolder_Click"
                Style="{StaticResource CustomButtonFontStyle}"
                HorizontalAlignment="Left" Grid.Row="2" VerticalAlignment="Bottom"
                Margin="100 0 0 10" Visibility="Collapsed"/>

        <StackPanel Orientation="Vertical" HorizontalAlignment="Right" Grid.Row="2" Margin="0 0 10 10" >
            <Image x:Name="brandLogo" Width="150" Height="50" 
                   VerticalAlignment="Top" HorizontalAlignment="Right" 
                   Margin="0 0 0 0"/>
            <TextBlock x:Name="FooterText" Style="{StaticResource CustomFontStyle}" FontSize="12" Foreground="white" 
                       HorizontalAlignment="Right" 
                       VerticalAlignment="Bottom"/>
        </StackPanel>
    </Grid>
</Window>
