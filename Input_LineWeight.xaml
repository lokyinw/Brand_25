<Window x:Class="Brand_25.Input_LineWeight"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Line Weight" Height="330" Width="540" WindowStartupLocation="CenterScreen"
        Background="LightGray"
        WindowStyle="None" ResizeMode="NoResize">

    <WindowChrome.WindowChrome>
        <WindowChrome GlassFrameThickness="0" CornerRadius="0" CaptionHeight="0"/>
    </WindowChrome.WindowChrome>
    <Window.Resources>
        <Style x:Key="TitleBarButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="bdr_main" BorderThickness="1" BorderBrush="Transparent" Background="Transparent">
                            <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Center" ContentSource="Content"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bdr_main" Property="Background" Value="#a7a7a7"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bdr_main" Property="Background" Value="#979797"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="CustomButtonFontStyle" TargetType="Button">
            <Setter Property="FontFamily" Value="Calibri"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Regular"/>
        </Style>
        <Style x:Key="CustomFontStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Calibri"/>
            <Setter Property="FontWeight" Value="Regular"/>
        </Style>
        <Style x:Key="CustomComboFontStyle" TargetType="ComboBox">
            <Setter Property="FontFamily" Value="Calibri"/>
            <Setter Property="FontSize" Value="16"/>
        </Style>
    </Window.Resources>

    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="35"/>
            <RowDefinition Height="*" />
            <RowDefinition Height="72"/>
        </Grid.RowDefinitions>

        <!-- Title bar -->
        <Grid Grid.Row="0" MouseLeftButtonDown="Window_MouseLeftButtonDown" Background="#474747">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="35"/>
            </Grid.ColumnDefinitions>
            <StackPanel Orientation="Horizontal" Background="Transparent" HorizontalAlignment="left" VerticalAlignment="Center">
                <Image x:Name="icon" Width="25" Height="25" Margin="5 0 0 0"/>
                <TextBlock Foreground="White" Name="TitleText" Text="Elevation Outline Line Weight" FontSize="16" VerticalAlignment="Center" Margin="10 0 0 0"
                           Style="{StaticResource CustomFontStyle}"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Grid.Column="1" Background="#474747">
                <Button Style="{StaticResource TitleBarButtonStyle}" x:Name="buttonClose" Width="35" Background="Transparent" BorderBrush="Transparent"
                        Click="buttonClose_Click">
                    <Image x:Name="closeImage" Width="20" Height="20"/>
                </Button>
            </StackPanel>
        </Grid>

        <!-- Body -->
        <StackPanel Grid.Row="1" Margin="15 10 15 0">
            <TextBlock Name="MessageText" TextWrapping="Wrap" TextAlignment="Left"
                       Style="{StaticResource CustomFontStyle}" FontSize="18" Foreground="#272727"
                       Text="Select the internal elevation view type. Click OK to apply the chosen line weight to their outlines, or Restore to clear existing overrides."
                       Margin="0 0 0 15"/>

            <TextBlock Text="Elevation View Type:" Style="{StaticResource CustomFontStyle}" FontSize="14" Foreground="#272727" Margin="0 0 0 4"/>
            <ComboBox x:Name="ViewTypeCombo" Style="{StaticResource CustomComboFontStyle}"
                      DisplayMemberPath="Name" Height="30" Margin="0 0 0 20"/>

            <TextBlock Text="Line Weight (1 - 16):" Style="{StaticResource CustomFontStyle}" FontSize="14" Foreground="#272727" Margin="0 0 0 4"/>
            <ComboBox x:Name="LineWeightCombo" Style="{StaticResource CustomComboFontStyle}"
                      Height="30" SelectedIndex="0"/>
        </StackPanel>

        <!-- Footer -->
        <Button Content="OK" Width="80" Height="30" Click="ButtonOk_Click"
                Style="{StaticResource CustomButtonFontStyle}"
                HorizontalAlignment="Left" Grid.Row="2" VerticalAlignment="Top"
                Margin="15 0 0 10"/>

        <Button Content="Restore" Width="80" Height="30" Click="ButtonRestore_Click"
                Style="{StaticResource CustomButtonFontStyle}"
                HorizontalAlignment="Left" Grid.Row="2" VerticalAlignment="Top"
                Margin="105 0 0 10"/>

        <Button Content="Cancel" Width="80" Height="30" Click="ButtonCancel_Click"
                Style="{StaticResource CustomButtonFontStyle}"
                HorizontalAlignment="Left" Grid.Row="2" VerticalAlignment="Top"
                Margin="195 0 0 10"/>

        <StackPanel Orientation="Vertical" HorizontalAlignment="Right" Grid.Row="2" Margin="0 0 10 10">
            <Image x:Name="brandLogo" Width="150" Height="50"
                   VerticalAlignment="Top" HorizontalAlignment="Right"
                   Margin="0 0 0 0"/>
            <TextBlock x:Name="FooterText" Style="{StaticResource CustomFontStyle}" FontSize="12" Foreground="white"
                       HorizontalAlignment="Right"
                       VerticalAlignment="Bottom"/>
        </StackPanel>
    </Grid>
</Window>
