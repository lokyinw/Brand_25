<Window x:Class="Brand_25.Selection_SheetLayout"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Place Internal Elevations on Sheet" Height="560" Width="480" WindowStartupLocation="CenterScreen"
        Background="LightGray" WindowStyle="None">

    <WindowChrome.WindowChrome>
        <WindowChrome GlassFrameThickness="0" CornerRadius="0" CaptionHeight="0"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <Style x:Key="TitleBarButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="bdr_main" BorderThickness="1" BorderBrush="Transparent" Background="Transparent">
                            <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Center" ContentSource="Content"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bdr_main" Property="Background" Value="#a7a7a7"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bdr_main" Property="Background" Value="#979797"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="CustomButtonFontStyle" TargetType="Button">
            <Setter Property="FontFamily" Value="Calibri"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Regular"/>
        </Style>
        <Style x:Key="CustomFontStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Calibri"/>
            <Setter Property="FontWeight" Value="Regular"/>
        </Style>
        <Style x:Key="LabelStyle" TargetType="TextBlock" BasedOn="{StaticResource CustomFontStyle}">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="#272727"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0 0 10 0"/>
        </Style>
        <Style x:Key="InputFontStyle" TargetType="Control">
            <Setter Property="FontFamily" Value="Calibri"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>
    </Window.Resources>

    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="35"/>
            <RowDefinition Height="*" />
            <RowDefinition Height="72"/>
        </Grid.RowDefinitions>

        <!-- Title Bar -->
        <Grid Grid.Row="0" MouseLeftButtonDown="Window_MouseLeftButtonDown" Background="#474747">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="105"/>
            </Grid.ColumnDefinitions>
            <StackPanel Orientation="Horizontal" Background="Transparent" HorizontalAlignment="Left" VerticalAlignment="Center">
                <Image x:Name="icon" Width="25" Height="25" Margin="5 0 0 0"/>
                <TextBlock Foreground="White" Name="TitleText" FontSize="16" VerticalAlignment="Center" Margin="10 0 0 0"
                           Style="{StaticResource CustomFontStyle}"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Grid.Column="1" Background="#474747" >
                <Button Style="{StaticResource TitleBarButtonStyle}" x:Name="buttonMinimize" Width="35" Background="Transparent" BorderBrush="Transparent"
                        Click="buttonMinimize_Click">
                    <Image x:Name="minimizeImage" Width="20" Height="20"/>
                </Button>
                <Button Style="{StaticResource TitleBarButtonStyle}" x:Name="buttonMaximize" Width="35" Background="Transparent" BorderBrush="Transparent"
                         Click="buttonMaximize_Click">
                    <Image x:Name="maximizeImage" Width="20" Height="20"/>
                </Button>
                <Button Style="{StaticResource TitleBarButtonStyle}" x:Name="buttonClose" Width="35" Background="Transparent" BorderBrush="Transparent"
                        Click="buttonClose_Click">
                    <Image x:Name="closeImage" Width="20" Height="20"/>
                </Button>
            </StackPanel>
        </Grid>

        <!-- Form fields -->
        <StackPanel Grid.Row="1" Margin="20 15 20 0">

            <TextBlock Text="Starting Sheet" Style="{StaticResource LabelStyle}" FontSize="16" Margin="0 0 0 4"/>
            <TextBox x:Name="SheetNumberBox" Style="{StaticResource InputFontStyle}" Height="26" Margin="0 0 0 16"/>

            <TextBlock Text="Elevation View Type" Style="{StaticResource LabelStyle}" FontSize="16" Margin="0 0 0 4"/>
            <ComboBox x:Name="ViewTypeCombo" Style="{StaticResource InputFontStyle}" Height="26" Margin="0 0 0 16" DisplayMemberPath="Name"/>

            <TextBlock Text="Phase" Style="{StaticResource LabelStyle}" FontSize="16" Margin="0 0 0 4"/>
            <ComboBox x:Name="PhaseCombo" Style="{StaticResource InputFontStyle}" Height="26" Margin="0 0 0 16" DisplayMemberPath="Name"/>

            <Grid Margin="0 0 0 16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Margin="0 0 10 0">
                    <TextBlock Text="Left Margin (mm)" Style="{StaticResource LabelStyle}" Margin="0 0 0 4"/>
                    <TextBox x:Name="LeftMarginBox" Style="{StaticResource InputFontStyle}" Height="26"/>
                </StackPanel>
                <StackPanel Grid.Column="1">
                    <TextBlock Text="X Spacing (mm)" Style="{StaticResource LabelStyle}" Margin="0 0 0 4"/>
                    <TextBox x:Name="XSpacingBox" Style="{StaticResource InputFontStyle}" Height="26"/>
                </StackPanel>
            </Grid>

            <Grid Margin="0 0 0 16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Margin="0 0 10 0">
                    <TextBlock Text="Y Spacing (mm)" Style="{StaticResource LabelStyle}" Margin="0 0 0 4"/>
                    <TextBox x:Name="YSpacingBox" Style="{StaticResource InputFontStyle}" Height="26"/>
                </StackPanel>
                <StackPanel Grid.Column="1">
                    <TextBlock Text="Lower Margin (mm)" Style="{StaticResource LabelStyle}" Margin="0 0 0 4"/>
                    <TextBox x:Name="LowerMarginBox" Style="{StaticResource InputFontStyle}" Height="26"/>
                </StackPanel>
            </Grid>

            <TextBlock Text="Return Width (mm)" Style="{StaticResource LabelStyle}" Margin="0 0 0 4"/>
            <TextBox x:Name="ReturnWidthBox" Style="{StaticResource InputFontStyle}" Height="26" Margin="0 0 0 16"/>

            <TextBlock Text="Level Line Trim (scale factor)" Style="{StaticResource LabelStyle}" Margin="0 0 0 4"/>
            <TextBox x:Name="LevelLineScaleBox" Style="{StaticResource InputFontStyle}" Height="26" Margin="0 0 0 16"/>

            <TextBlock x:Name="ErrorText" Foreground="Red" Style="{StaticResource CustomFontStyle}" FontSize="13"
                       TextWrapping="Wrap" Visibility="Collapsed"/>
        </StackPanel>

        <!-- Buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="20 0 0 10">
            <Button Style="{StaticResource CustomButtonFontStyle}" Content="Place on Sheet" Width="150" Margin="0 0 10 0" Click="OK_Click"/>
            <Button Style="{StaticResource CustomButtonFontStyle}" Content="Cancel" Width="80" Click="Cancel_Click"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Vertical" HorizontalAlignment="Right" Margin="0 0 10 10">
            <Image x:Name="brandLogo" Width="150" Height="50"
                   VerticalAlignment="Top" HorizontalAlignment="Right"
                   Margin="0 0 0 0"/>
            <TextBlock x:Name="FooterText" Style="{StaticResource CustomFontStyle}" FontSize="12" Foreground="white"
                       HorizontalAlignment="Right"
                       VerticalAlignment="Bottom"/>
        </StackPanel>

    </Grid>
</Window>
