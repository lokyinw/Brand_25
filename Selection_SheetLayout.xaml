<Window x:Class="Brand_25.Selection_SheetLayout"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Place Internal Elevations on Sheet" Height="810" Width="500" WindowStartupLocation="CenterScreen"
        Background="LightGray" WindowStyle="None">

    <WindowChrome.WindowChrome>
        <WindowChrome GlassFrameThickness="0" CornerRadius="0" CaptionHeight="0"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <Style x:Key="TitleBarButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="bdr_main" BorderThickness="1" BorderBrush="Transparent" Background="Transparent">
                            <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Center" ContentSource="Content"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bdr_main" Property="Background" Value="#a7a7a7"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bdr_main" Property="Background" Value="#979797"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="CustomButtonFontStyle" TargetType="Button">
            <Setter Property="FontFamily" Value="Calibri"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Regular"/>
        </Style>
        <Style x:Key="CustomFontStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Calibri"/>
            <Setter Property="FontWeight" Value="Regular"/>
        </Style>
        <Style x:Key="LabelStyle" TargetType="TextBlock" BasedOn="{StaticResource CustomFontStyle}">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="#272727"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0 0 10 0"/>
        </Style>
        <Style x:Key="SectionHeaderStyle" TargetType="TextBlock" BasedOn="{StaticResource CustomFontStyle}">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#474747"/>
            <Setter Property="Margin" Value="0 14 0 6"/>
        </Style>
        <Style x:Key="InputFontStyle" TargetType="Control">
            <Setter Property="FontFamily" Value="Calibri"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <!--<Setter Property="Margin" Value="10 0 0 0"/>-->
            <Setter Property="Padding" Value="5 0 0 0"/>
        </Style>
    </Window.Resources>

    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="35"/>
            <RowDefinition Height="*" />
            <RowDefinition Height="72"/>
        </Grid.RowDefinitions>

        <!-- Title Bar -->
        <Grid Grid.Row="0" MouseLeftButtonDown="Window_MouseLeftButtonDown" Background="#474747">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="105"/>
            </Grid.ColumnDefinitions>
            <StackPanel Orientation="Horizontal" Background="Transparent" HorizontalAlignment="Left" VerticalAlignment="Center">
                <Image x:Name="icon" Width="25" Height="25" Margin="5 0 0 0"/>
                <TextBlock Foreground="White" Name="TitleText" FontSize="16" VerticalAlignment="Center" Margin="10 0 0 0"
                           Style="{StaticResource CustomFontStyle}"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Grid.Column="1" Background="#474747" >
                <Button Style="{StaticResource TitleBarButtonStyle}" x:Name="buttonMinimize" Width="35" Background="Transparent" BorderBrush="Transparent"
                        Click="buttonMinimize_Click">
                    <Image x:Name="minimizeImage" Width="20" Height="20"/>
                </Button>
                <Button Style="{StaticResource TitleBarButtonStyle}" x:Name="buttonMaximize" Width="35" Background="Transparent" BorderBrush="Transparent"
                         Click="buttonMaximize_Click">
                    <Image x:Name="maximizeImage" Width="20" Height="20"/>
                </Button>
                <Button Style="{StaticResource TitleBarButtonStyle}" x:Name="buttonClose" Width="35" Background="Transparent" BorderBrush="Transparent"
                        Click="buttonClose_Click">
                    <Image x:Name="closeImage" Width="20" Height="20"/>
                </Button>
            </StackPanel>
        </Grid>

        <!-- Form fields -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="20 15 20 0">

                <TextBlock Text="Starting Sheet" Style="{StaticResource LabelStyle}" FontSize="14" Margin="0 0 0 4"/>
                <TextBox x:Name="SheetNumberBox" Style="{StaticResource InputFontStyle}" Height="26" Margin="0 0 0 6"/>

                <TextBlock Text="Elevation View Type" Style="{StaticResource LabelStyle}" FontSize="14" Margin="0 0 0 4"/>
                <ComboBox x:Name="ViewTypeCombo" Style="{StaticResource InputFontStyle}" Height="26" Padding="7 0 0 0" Margin="0 0 0 6" DisplayMemberPath="Name"/>

                <TextBlock Text="Phase" Style="{StaticResource LabelStyle}" FontSize="14" Margin="0 0 0 4"/>
                <ComboBox x:Name="PhaseCombo" Style="{StaticResource InputFontStyle}" Height="26" Padding="7 0 0 0" Margin="0 0 0 6" DisplayMemberPath="Name"/>

                <!-- Paper -->
                <TextBlock Text="Paper Size" Style="{StaticResource SectionHeaderStyle}" Margin="0 50 0 4"/>
                <Grid Margin="0 0 0 20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0 0 10 0">
                        <TextBlock Text="Paper Width (mm)" Style="{StaticResource LabelStyle}" Margin="0 0 0 4"/>
                        <TextBox x:Name="PaperWidthBox" Style="{StaticResource InputFontStyle}" Height="26"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="Paper Height (mm)" Style="{StaticResource LabelStyle}" Margin="0 0 0 4"/>
                        <TextBox x:Name="PaperHeightBox" Style="{StaticResource InputFontStyle}" Height="26"/>
                    </StackPanel>
                </Grid>
                
                <TextBlock Text="Frame Margins (paper edge → title frame)" Style="{StaticResource SectionHeaderStyle}" Margin="0 35 0 4"/>
                <Grid Margin="0 0 0 10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Top Margin -->
                    <StackPanel Grid.Column="0" Margin="0 0 10 0">
                        <TextBlock Text="Top (mm)" Style="{StaticResource LabelStyle}" Margin="0 0 0 4"/>
                        <TextBox x:Name="FrameMarginTopBox" Style="{StaticResource InputFontStyle}" Height="26"/>
                    </StackPanel>

                    <!-- Bottom Margin -->
                    <StackPanel Grid.Column="1" Margin="0 0 10 0">
                        <TextBlock Text="Bottom (mm)" Style="{StaticResource LabelStyle}" Margin="0 0 0 4"/>
                        <TextBox x:Name="FrameMarginBottomBox" Style="{StaticResource InputFontStyle}" Height="26"/>
                    </StackPanel>

                    <!-- Left Margin -->
                    <StackPanel Grid.Column="2" Margin="0 0 10 0">
                        <TextBlock Text="Left (mm)" Style="{StaticResource LabelStyle}" Margin="0 0 0 4"/>
                        <TextBox x:Name="FrameMarginLeftBox" Style="{StaticResource InputFontStyle}" Height="26"/>
                    </StackPanel>

                    <!-- Right Margin -->
                    <StackPanel Grid.Column="3">
                        <TextBlock Text="Right (mm)" Style="{StaticResource LabelStyle}" Margin="0 0 0 4"/>
                        <TextBox x:Name="FrameMarginRightBox" Style="{StaticResource InputFontStyle}" Height="26"/>
                    </StackPanel>
                </Grid>

                <!-- Content margins: title frame -> drawing area -->
                <!--<TextBlock Text="Content Margins (title frame → drawing area)" Style="{StaticResource SectionHeaderStyle}"/>
                <Grid Margin="0 0 0 8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0 0 10 0">
                        <TextBlock Text="Top (mm)" Style="{StaticResource LabelStyle}" Margin="0 0 0 4"/>
                        <TextBox x:Name="ContentMarginTopBox" Style="{StaticResource InputFontStyle}" Height="26"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="Bottom (mm)" Style="{StaticResource LabelStyle}" Margin="0 0 0 4"/>
                        <TextBox x:Name="ContentMarginBottomBox" Style="{StaticResource InputFontStyle}" Height="26"/>
                    </StackPanel>
                </Grid>
                <Grid Margin="0 0 0 16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0 0 10 0">
                        <TextBlock Text="Left (mm)" Style="{StaticResource LabelStyle}" Margin="0 0 0 4"/>
                        <TextBox x:Name="ContentMarginLeftBox" Style="{StaticResource InputFontStyle}" Height="26"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="Drawing Info Area Width (mm)" Style="{StaticResource LabelStyle}" Margin="0 0 0 4"/>
                        <TextBox x:Name="ContentMarginRightBox" Style="{StaticResource InputFontStyle}" Height="26"/>
                    </StackPanel>
                </Grid>-->

                <TextBlock Text="Content Margins (title frame → drawing area)" Style="{StaticResource SectionHeaderStyle}" Margin="0 0 0 4"/>
                <Grid Margin="0 0 0 50">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Top Margin -->
                    <StackPanel Grid.Column="0" Margin="0 0 10 0">
                        <TextBlock Text="Top (mm)" Style="{StaticResource LabelStyle}" Margin="0 0 0 4"/>
                        <TextBox x:Name="ContentMarginTopBox" Style="{StaticResource InputFontStyle}" Height="26"/>
                    </StackPanel>

                    <!-- Bottom Margin -->
                    <StackPanel Grid.Column="1" Margin="0 0 10 0">
                        <TextBlock Text="Bottom (mm)" Style="{StaticResource LabelStyle}" Margin="0 0 0 4"/>
                        <TextBox x:Name="ContentMarginBottomBox" Style="{StaticResource InputFontStyle}" Height="26"/>
                    </StackPanel>

                    <!-- Left Margin -->
                    <StackPanel Grid.Column="2" Margin="0 0 10 0">
                        <TextBlock Text="Left (mm)" Style="{StaticResource LabelStyle}" Margin="0 0 0 4"/>
                        <TextBox x:Name="ContentMarginLeftBox" Style="{StaticResource InputFontStyle}" Height="26"/>
                    </StackPanel>

                    <!-- Drawing Info Area Width -->
                    <StackPanel Grid.Column="3">
                        <TextBlock Text="Title block Width" Style="{StaticResource LabelStyle}" Margin="0 0 0 4"/>
                        <TextBox x:Name="ContentMarginRightBox" Style="{StaticResource InputFontStyle}" Height="26"/>
                    </StackPanel>
                </Grid>

                <!-- Viewport layout -->
                <TextBlock Text="Viewport Layout" Style="{StaticResource SectionHeaderStyle}" Margin="0 10 0 4"/>
                <Grid Margin="0 0 0 10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0 0 10 0">
                        <TextBlock Text="X Spacing (mm)" Style="{StaticResource LabelStyle}" Margin="0 0 0 4"/>
                        <TextBox x:Name="XSpacingBox" Style="{StaticResource InputFontStyle}" Height="26"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="Y Spacing (mm)" Style="{StaticResource LabelStyle}" Margin="0 0 0 4"/>
                        <TextBox x:Name="YSpacingBox" Style="{StaticResource InputFontStyle}" Height="26"/>
                    </StackPanel>
                </Grid>

                <!-- Level lines -->
                <!-- <TextBlock Text="Level Lines" Style="{StaticResource SectionHeaderStyle}" Margin="0 10 0 4"/> -->
                <TextBlock Text="Level Extension beyond crop box (mm)" Style="{StaticResource SectionHeaderStyle}" Margin="0 0 0 4"/>
                <TextBox x:Name="LevelExtensionBox" Style="{StaticResource InputFontStyle}" Height="26" Margin="0 0 0 16"/>

                <TextBlock x:Name="ErrorText" Foreground="Red" Style="{StaticResource CustomFontStyle}" FontSize="13"
                       TextWrapping="Wrap" Visibility="Collapsed"/>
            </StackPanel>
        </ScrollViewer>

        <!-- Buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="20 0 0 10">
            <Button Style="{StaticResource CustomButtonFontStyle}" Content="Place on Sheet" Width="130" Margin="0 0 10 0" Click="OK_Click"/>
            <Button Style="{StaticResource CustomButtonFontStyle}" Content="Cancel" Width="80" Click="Cancel_Click"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Vertical" HorizontalAlignment="Right" Margin="0 0 10 10">
            <Image x:Name="brandLogo" Width="150" Height="50"
                   VerticalAlignment="Top" HorizontalAlignment="Right"
                   Margin="0 0 0 0"/>
            <TextBlock x:Name="FooterText" Style="{StaticResource CustomFontStyle}" FontSize="12" Foreground="white"
                       HorizontalAlignment="Right"
                       VerticalAlignment="Bottom"/>
        </StackPanel>

    </Grid>
</Window>
