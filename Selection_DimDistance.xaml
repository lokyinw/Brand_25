<Window x:Class="Brand_25.Selection_DimDistance"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Dimension Line Distances" Height="380" Width="480" WindowStartupLocation="CenterScreen"
        Background="LightGray" WindowStyle="None">
    <WindowChrome.WindowChrome>
        <WindowChrome GlassFrameThickness="0" CornerRadius="0" CaptionHeight="0"/>
    </WindowChrome.WindowChrome>
    <Window.Resources>
        <Style x:Key="TitleBarButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="bdr_main" BorderThickness="1" BorderBrush="Transparent" Background="Transparent">
                            <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Center" ContentSource="Content"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bdr_main" Property="Background" Value="#a7a7a7"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bdr_main" Property="Background" Value="#979797"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="CustomButtonFontStyle" TargetType="Button">
            <Setter Property="FontFamily" Value="Calibri"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Regular"/>
        </Style>
        <Style x:Key="CustomFontStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Calibri"/>
            <Setter Property="FontWeight" Value="Regular"/>
        </Style>
        <Style x:Key="LabelStyle" TargetType="TextBlock" BasedOn="{StaticResource CustomFontStyle}">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Margin" Value="0 0 0 4"/>
        </Style>
        <Style x:Key="InputBoxStyle" TargetType="TextBox">
            <Setter Property="FontFamily" Value="Calibri"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Width" Value="120"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="Padding" Value="4"/>
        </Style>
    </Window.Resources>
    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="35"/>
            <RowDefinition Height="*" />
            <RowDefinition Height="72"/>
        </Grid.RowDefinitions>

        <!-- Title Bar -->
        <Grid Grid.Row="0" MouseLeftButtonDown="Window_MouseLeftButtonDown" Background="#474747">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="105"/>
            </Grid.ColumnDefinitions>
            <StackPanel Orientation="Horizontal" Background="Transparent" HorizontalAlignment="Left" VerticalAlignment="Center">
                <Image x:Name="icon" Width="25" Height="25" Margin="5 0 0 0"/>
                <TextBlock Foreground="White" Name="TitleText" FontSize="16" VerticalAlignment="Center" Margin="10 0 0 0"
                           Style="{StaticResource CustomFontStyle}"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Grid.Column="1" Background="#474747" >
                <Button Style="{StaticResource TitleBarButtonStyle}" x:Name="buttonMinimize" Width="35" Background="Transparent" BorderBrush="Transparent"
                        Click="buttonMinimize_Click">
                    <Image x:Name="minimizeImage" Width="20" Height="20"/>
                </Button>
                <Button Style="{StaticResource TitleBarButtonStyle}" x:Name="buttonMaximize" Width="35" Background="Transparent" BorderBrush="Transparent"
                        Click="buttonMaximize_Click">
                    <Image x:Name="maximizeImage" Width="20" Height="20"/>
                </Button>
                <Button Style="{StaticResource TitleBarButtonStyle}" x:Name="buttonClose" Width="35" Background="Transparent" BorderBrush="Transparent"
                        Click="buttonClose_Click">
                    <Image x:Name="closeImage" Width="20" Height="20"/>
                </Button>
            </StackPanel>
        </Grid>

        <!-- Inputs -->
        <StackPanel Grid.Row="1" Margin="20 20 20 0">
            <TextBlock Text="All distances are in millimetres, measured in paper space (they are scaled by each view's Scale automatically)."
                       Style="{StaticResource CustomFontStyle}" FontSize="13" TextWrapping="Wrap" Margin="0 0 0 16" Foreground="#333333"/>

            <TextBlock Text="Distance 1 — overall width / height dimension (closest to the element)" Style="{StaticResource LabelStyle}"/>
            <TextBox x:Name="Dist1Box" Style="{StaticResource InputBoxStyle}" Text="7" Margin="0 0 0 14"/>

            <TextBlock Text="Distance 2 — overall height tied to Level (used when curtain grids are present)" Style="{StaticResource LabelStyle}"/>
            <TextBox x:Name="Dist2Box" Style="{StaticResource InputBoxStyle}" Text="12" Margin="0 0 0 14"/>

            <TextBlock Text="Distance 3 — curtain grid width dimension / door width tie (furthest from the element)" Style="{StaticResource LabelStyle}"/>
            <TextBox x:Name="Dist3Box" Style="{StaticResource InputBoxStyle}" Text="15" Margin="0 0 0 14"/>
        </StackPanel>

        <!-- Buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="10 0 0 10">
            <Button Style="{StaticResource CustomButtonFontStyle}" Content="OK" Width="120" Margin="0 0 10 0" Click="OK_Click"/>
            <Button Style="{StaticResource CustomButtonFontStyle}" Content="Cancel" Width="80" Click="Cancel_Click"/>
        </StackPanel>
        <StackPanel Grid.Row="2" Orientation="Vertical" HorizontalAlignment="Right" Margin="0 0 10 10">
            <Image x:Name="brandLogo" Width="150" Height="50"
                   VerticalAlignment="Top" HorizontalAlignment="Right"
                   Margin="0 0 0 0"/>
            <TextBlock x:Name="FooterText" Style="{StaticResource CustomFontStyle}" FontSize="12" Foreground="white"
                       HorizontalAlignment="Right"
                       VerticalAlignment="Bottom"/>
        </StackPanel>
    </Grid>
</Window>
